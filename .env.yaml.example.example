# ============================================================
# CREDENTIALS — Fill each value, then add as GitHub Secrets
# DO NOT commit this file. It is in .gitignore.
# Budget: ~$15/yr ($5 Pushover + ~$10 GPT-4o-mini). $185 reserve.
# ============================================================

# WordPress (KnownHost — brother hosts free)
# App Password: wp-admin > Users > Profile > Application Passwords
WP_URL: ""                    # https://yourdomain.com
WP_USERNAME: ""
WP_APP_PASSWORD: ""

# JSearch API (primary, Google for Jobs data)
# rapidapi.com > JSearch > subscribe free tier > dashboard
JSEARCH_API_KEY: ""

# Jooble API (secondary)
# jooble.org/api/about > register > key by email
JOOBLE_API_KEY: ""

# Adzuna API (tertiary)
# developer.adzuna.com > register > get app_id + app_key
ADZUNA_APP_ID: ""
ADZUNA_APP_KEY: ""

# USAJobs API (federal government, unique coverage)
# developer.usajobs.gov > register > get API key
# Auth uses User-Agent header, not query param
USAJOBS_EMAIL: ""             # email used to register
USAJOBS_API_KEY: ""           # API key from developer.usajobs.gov

# Groq (primary LLM classifier, free)
# console.groq.com > API Keys > Create
GROQ_API_KEY: ""

# Google Gemini (fallback LLM, free)
# ai.google.dev > Get API Key > Create
GEMINI_API_KEY: ""

# OpenAI (safety net LLM, ~$10/yr)
# platform.openai.com > API Keys > Create > add $10 credit
OPENAI_API_KEY: ""

# Turso Database (free cloud SQLite)
# app.turso.tech > create database "jobmonitor" > region "iad"
TURSO_DB_URL: ""              # libsql://jobmonitor-yourname.turso.io
TURSO_AUTH_TOKEN: ""

# Brevo SMTP (free email, 300/day)
# brevo.com > Settings > SMTP & API > SMTP tab
BREVO_SMTP_USER: ""
BREVO_SMTP_PASS: ""
NOTIFICATION_EMAIL: ""        # your personal email

# Pushover (instant mobile push, $5 one-time)
# pushover.net > register > Create Application
PUSHOVER_USER_KEY: ""
PUSHOVER_APP_TOKEN: ""

# Healthchecks.io (free cron monitoring)
# healthchecks.io > Add Check > period 24h > grace 6h
HEALTHCHECK_URL: ""           # https://hc-ping.com/xxxxxxxx

# Google Alerts RSS feeds (google.com/alerts > Show options > RSS feed)
GOOGLE_ALERT_RSS_1: ""        # "employee listening" hiring OR careers
GOOGLE_ALERT_RSS_2: ""        # "people analytics" manager OR director job
GOOGLE_ALERT_RSS_3: ""        # "voice of employee" job OR role
GOOGLE_ALERT_RSS_4: ""        # "workforce sensing" OR "continuous listening" hiring
GOOGLE_ALERT_RSS_5: ""        # "people insights" OR "employee insights" job
GOOGLE_ALERT_SIOP: ""         # site:jobs.siop.org (SIOP career center monitor)

# Talkwalker Alerts RSS (talkwalker.com/alerts > RSS delivery)
TALKWALKER_RSS_1: ""          # "employee listening" jobs
TALKWALKER_RSS_2: ""          # "people analytics" hiring
TALKWALKER_RSS_3: ""          # "workforce analytics" OR "talent analytics" careers
